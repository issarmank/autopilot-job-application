# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jobtracker

# Auth.js
AUTH_SECRET=                    # generate with: openssl rand -base64 32
AUTH_GITHUB_ID=                 # GitHub OAuth app client ID
AUTH_GITHUB_SECRET=             # GitHub OAuth app client secret
AUTH_GOOGLE_ID=                 # Google OAuth client ID (console.cloud.google.com)
AUTH_GOOGLE_SECRET=             # Google OAuth client secret

# OpenRouter (Gemini Flash) — LLM extraction (extension raw-text fallback,
# GitHub source) and internship ranking
OPENROUTER_API_KEY=

# GitHub API (Phase 2 GitHub source) — optional but recommended:
# 5000 req/hour with a token vs 60 without. Personal access token, public_repo scope.
GITHUB_TOKEN=

# Adzuna Jobs API (Phase 4 internship recommendations) — free tier
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Redis (BullMQ) — required for the watched-repo sync worker (src/worker.ts)
REDIS_URL=redis://localhost:6379
# How often the worker re-syncs every watched repo, in hours
REPO_SYNC_INTERVAL_HOURS=12

# --- Deferred (not needed yet) ---
# RESEND_API_KEY=
# EMAIL_FROM=
